# syntax=docker/dockerfile:1.7
FROM ghcr.io/astral-sh/uv:python3.11-bookworm-slim

ARG OMNIVOICE_MODEL_ID=k2-fsa/OmniVoice

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    UV_LINK_MODE=copy \
    PATH=/app/.venv/bin:$PATH \
    PORT=8000 \
    HOST=0.0.0.0 \
    HF_HOME=/workspace/models/huggingface \
    MODEL_DIR=/workspace/models \
    AUDIO_SEPARATOR_MODEL_DIR=/workspace/models/audio-separator \
    WHISPER_MODEL_DIR=/workspace/models/whisper \
    OMNIVOICE_ASR_BACKEND=qwen3 \
    OMNIVOICE_MAX_REQUEST_MB=512 \
    SEPARATION_MODEL=vocals_mel_band_roformer.ckpt \
    OMNIVOICE_MODEL_ID=${OMNIVOICE_MODEL_ID} \
    VOXCPM_LOAD_DENOISER=0 \
    VOXCPM_OPTIMIZE=0 \
    VOXCPM_TRIM_LEADING_SILENCE=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    curl \
    ffmpeg \
    git \
    libgl1 \
    libglib2.0-0 \
    libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml uv.lock README.md /app/
COPY omnivoice/ /app/omnivoice/
COPY voxcpm/ /app/voxcpm/
COPY api.py /app/api.py
COPY speaker_embedding.py /app/speaker_embedding.py
COPY docker/entrypoint.sh /usr/local/bin/omnivoice-api-entrypoint

RUN uv sync --frozen --no-dev \
    && chmod +x /usr/local/bin/omnivoice-api-entrypoint \
    && mkdir -p "${HF_HOME}" "${MODEL_DIR}" "${AUDIO_SEPARATOR_MODEL_DIR}" "${WHISPER_MODEL_DIR}" /app/work

EXPOSE 8000

ENTRYPOINT ["/usr/local/bin/omnivoice-api-entrypoint"]
